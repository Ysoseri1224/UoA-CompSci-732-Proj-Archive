{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "nodemon --exec tsx src/index.ts",
    "test": "node --import tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "test:unit": "node --import tsx --test --test-concurrency=1 tests/unit/**/*.test.ts",
    "test:db": "node --import tsx --test --test-concurrency=1 tests/db/**/*.test.ts",
    "test:api": "node --import tsx --test --test-concurrency=1 tests/api/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.3.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pokersolver": "^2.1.2",
    "redis": "^5.3.0",
    "socket.io": "^4.7.2",
    "xstate": "^5.31.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.0",
    "oxlint": "^1.63.0",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
