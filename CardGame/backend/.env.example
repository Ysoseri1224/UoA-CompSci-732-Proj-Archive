# 复制此文件为 .env 并填入真实值，.env 已被 .gitignore 忽略

# 服务端口
PORT=3000

# MongoDB 连接（Docker Compose 内部使用服务名 'mongo'）
MONGO_URI=mongodb://mongo:27017/balatro_db

# 数据库测试连接（从宿主机运行测试时使用 localhost）
TEST_MONGO_URI=mongodb://mongo:27017/balatro_test

# Redis 连接（Docker Compose 内部使用服务名 'redis'）
REDIS_URL=redis://redis:6379

# JWT 密钥（生产环境请使用强随机字符串，至少 32 位）
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here

# 前端地址（用于 CORS 配置）
CLIENT_ORIGIN=http://localhost:5173

# 认证接口限流（15分钟内最多10次）
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10
